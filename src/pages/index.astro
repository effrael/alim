    </div>
  </footer>

  <script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
    async function handleSubmit(e) {
      e.preventDefault();
      const form = e.currentTarget;
      const email = form.email.value.trim();
      const button = form.querySelector('button');

      button.disabled = true;
      button.innerHTML = 'Guardando...';

      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
          method: 'POST',
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${SUPABASE_KEY}`,
            'Content-Type': 'application/json',
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({ email, source: 'landing' })
        });

        // 409 = email ya registrado -> lo tratamos como éxito
        if (!res.ok && res.status !== 409) {
          throw new Error(await res.text());
        }

        localStorage.setItem('alim_waitlist', '1');
        showJoinedState();
      } catch (err) {
        console.error('[waitlist]', err);
        button.disabled = false;
        button.innerHTML = 'Unirme <i class="ti ti-arrow-right"></i>';
        alert('Algo falló. Intenta de nuevo en un rato.');
      }
    }

    // Oculta ambos formularios y muestra los mensajes de éxito
    function showJoinedState() {
      document.querySelectorAll('form.form').forEach((f) => f.classList.add('hidden'));
      document.querySelectorAll('.form-note').forEach((n) => n.classList.add('hidden'));
      document.querySelectorAll('.form-success').forEach((s) => s.classList.add('visible'));
    }

    // Si ya se inscribió antes desde este navegador, mostrar estado "dentro"
    if (localStorage.getItem('alim_waitlist')) {
      showJoinedState();
    }

    document.querySelectorAll('form.form').forEach((form) => {
      form.addEventListener('submit', handleSubmit);
    });
  </script>

</body>
